# --- OS / Editor ---
.DS_Store
Thumbs.db

# VS Code workspace state (keep settings/tasks in repo)
.vscode/*.log
.vscode/.ropeproject


# --- Build outputs (project-specific; extend as needed) ---
dist/
build/
out/

# --- Logs / temp ---
*.log
*.tmp
.tmp/

# --- Generated artifacts (repo policy) ---
# Keep all non-source artifacts under output/ and do not track them.
output/**
!output/.gitkeep

# --- Python 仮想環境 / キャッシュ ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Local sandbox (personal experiments, practice copies; never shared) ---
sandbox/
